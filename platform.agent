// platform.agent — the orchestrator of the Unboxd platform.
//
// This is an executable agent definition in ADL, the agent language: the
// structured, machine-checked counterpart to a freeform AGENTS.md. It describes
// the platform's top-level orchestrator agent — the one that owns the reconcile
// loop and drives tenants, services, providers, and deployments toward their
// desired state.
//
// Persistence and inference targets (surrealdb / surrealml) resolve to the
// SurrealDB-backed store provided by the agent-platform repo. The same runtime
// (pkg/adl, and via WASM the editor tooling) parses and validates this file;
// run it with `platform agent check platform.agent`.

namespace unboxd.platform

vocabulary platform {
    term tenant means "an isolated customer account on the platform"
    term reconcile means "drive observed state toward desired state"
    term service maps to unboxd.platform.Service
}

entity Tenant {
    id: string required
    name: string required
    plan: string
}

entity Service {
    name: string required
    image: string required
    tenant: Tenant
    replicas: int
}

entity Provider {
    name: string required
    kind: string required
    region: string
}

entity Deployment {
    service: Service required
    provider: Provider required
    desiredReplicas: int required
    healthy: bool
    updatedAt: datetime
}

relation RunsOn Deployment -> Provider {
    region: string
}

brain PlatformOrchestrator {
    owns data
    owns business_logic
    owns policy
    owns api
    owns permissions
    owns events
    owns live_queries
    owns memory
    owns beliefs
    owns decisions
}

mind ReconcileMind for Deployment {
    desiredState: string
    observedState: string
    nextAction: string
    confidence: float
}

belief DriftDetected {
    subject Deployment
    claim "deployment has drifted from its desired replica count"
    confidence 0.74
    source "reconcile-loop"
}

constitution PlatformConstitution {
    rule isolation: "never let one tenant's workload affect another tenant"
    rule leastPrivilege: "grant each service only the permissions it declares"
    rule auditable: "every state change must emit an event"
}

policy ReconcilePolicy {
    rule converge: "continuously reconcile deployments toward desired state"
    rule backoff: "exponentially back off retries on provider errors"
}

policy AccessPolicy {
    rule scoped: "orchestrator actions are scoped to the owning tenant"
}

api get "/v1/services" returns surrealdb
api get "/v1/deployments" returns surrealdb
api post "/v1/deployments/{id}/reconcile" returns surrealdb

function unboxd.platform.reconcile(deployment: Deployment, force: bool) returns bool as surrealdb
function unboxd.platform.schedule(service: Service, replicas: int) returns Provider as surrealml

surrealml DriftScorer for scoring input Deployment output Deployment
surrealml PlacementRanker for ranking input Service output Provider
