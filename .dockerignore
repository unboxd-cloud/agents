# Keep the OCI build context small and reproducible. The Dockerfile builds a
# single service from source (./cmd/${SERVICE}) plus the embedded ADL model
# (platform.agent, metamodels/*.agent, blueprints/*.agent — see model.go), so
# everything below is either reproduced in the build stage or irrelevant to it.

# VCS + CI (never needed inside the image build)
.git
.github
.gitlab-ci.yml

# Build outputs — reproduced inside the build stage, must not leak from host
/bin/
/orgconsole
*.exe
*.test
*.out
/web/adl-runtime/adl.wasm

# Local env / editor / OS
.env
*.local
.DS_Store
.idea/
.vscode/
