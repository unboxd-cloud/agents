// economy.agent — the agent economy. Agents are economic actors: they offer
// services at a price, transact agent-to-agent against a budgeted wallet, list on
// a marketplace, and settle — every exchange governed and audited. Trust and
// performance (see trust.agent, eval.agent) shape pricing and selection; the
// platform KPI (ARR) is the aggregate.
namespace unboxd.meta.economy

// The economics the brain reasons from — first principles that teach good habits:
// scarcity, tradeoffs, opportunity cost, thinking at the margin, and responding to
// incentives (directly underwrites adapt/optimize/reduce in the constitution).
vocabulary canon {
    term principles_of_economics means "N. Gregory Mankiw, Principles of Economics — tradeoffs, opportunity cost, marginal thinking, incentives"
    term wealth_of_nations means "Adam Smith, The Wealth of Nations (1776) — division of labor, markets, the invisible hand"
    term use_of_knowledge means "F. A. Hayek, The Use of Knowledge in Society (1945) — the price system coordinates dispersed knowledge with no central order; agents move in the right direction on price signals alone"
    term exchange_and_production means "Alchian & Allen, Exchange and Production (University Economics) — the Alchian–Allen effect: a fixed per-unit cost lowers the relative price of the higher grade, so fixed per-call overhead biases selection toward the premium model/agent"
    term macroeconomics_and_reality means "C. Sims, Macroeconomics and Reality (1980) — the classical structural assumptions (linearity, error-free observation, fixed exogeneity, normal disturbances, dynamic stability) rarely hold; prefer empirical, non-stationary methods over assumed structure"
}

// Information economics — how asymmetric information shapes the agent market.
// The platform answers each with a mechanism: trust/reputation signals quality,
// the eval scorecard screens, governance counters moral hazard, and provenance
// counters adverse selection (cheap-but-bad agents/models).
vocabulary information {
    term asymmetry means "one side knows more than the other (a buyer can't see an agent's true quality)"
    term signaling means "the informed side proves quality — trust score, certifications, track record"
    term screening means "the uninformed side sorts quality — the CLEAR eval scorecard, benchmarks"
    term adverse_selection means "low quality drives out high when quality is hidden — countered by provenance"
    term moral_hazard means "an actor takes hidden risk once engaged — countered by governance and audit"
}

entity Actor {
    id: string required
    kind: string
}

entity Wallet {
    actor: Actor required
    balance: float
    currency: string
}

entity Offering {
    provider: Actor required
    name: string required
    price: float
    unit: string
}

entity Order {
    buyer: Actor required
    offering: Offering required
    quantity: float
}

entity Transaction {
    order: Order required
    amount: float
    settled: bool
}

entity Marketplace {
    name: string required
}

entity Listing {
    marketplace: Marketplace required
    offering: Offering required
    rank: int
}

relation Holds Actor -> Wallet {
    primary: bool
}

relation Offers Actor -> Offering {
    since: datetime
}

relation Lists Marketplace -> Listing {
    featured: bool
}

relation Settles Transaction -> Order {
    at: datetime
}

// Agent-to-agent value exchange, gated and audited like any A2A call.
relation Trades Actor -> Actor {
    via: string
}
