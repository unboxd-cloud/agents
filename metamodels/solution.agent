// solution.agent — the solution metamodel. Our agents are solution-centric:
// given a goal they dynamically generate a solution and a concrete plan, which
// must be confirmed (the propose -> approve gate) before any execution starts.
// Only a confirmed solution runs.
namespace unboxd.meta.solution

entity Goal {
    statement: string required
    priority: string
}

// Brief is the complete context an agent must understand before generating a
// solution: the problem statement, the deliverable, the project context, and the
// final target environment config. Until all are present, complete is false and
// the agent reports "complete context missing" rather than proceeding.
entity Brief {
    goal: Goal required
    problemStatement: string
    deliverable: string
    projectContext: string
    targetEnvConfig: string
    complete: bool
}

entity Solution {
    goal: Goal required
    rationale: string
    generated: bool
    confirmed: bool
    confirmedBy: string
    confirmedAt: datetime
}

entity Plan {
    solution: Solution required
    summary: string
}

entity PlanStep {
    plan: Plan required
    name: string required
    order: int
    tool: string
}

entity Execution {
    solution: Solution required
    status: string
    startedAt: datetime
    finishedAt: datetime
}

// Source is a data source an answer is grounded in; it must be verified.
entity Source {
    uri: string required
    kind: string
    verified: bool
}

// Answer is the deliverable: grounded in verified sources, actionable, and
// rendered in a business format (report or presentation).
entity Answer {
    format: string required
    actionable: bool
    grounded: bool
    summary: string
}

relation Solves Solution -> Goal {
    score: float
}

// A solution is grounded in a complete Brief; it is not generated until the
// brief is complete and confirmed.
relation Grounds Solution -> Brief {
    confirmed: bool
}

relation HasPlan Solution -> Plan {
    version: int
}

relation DecomposesInto Plan -> PlanStep {
    order: int
}

// Execution runs a solution only once it is confirmed (confirm-before-execute).
relation Runs Execution -> Solution {
    onlyIfConfirmed: bool
}

// An execution produces an answer, grounded in verified sources.
relation Produces Execution -> Answer {
    at: datetime
}

relation GroundedIn Answer -> Source {
    verified: bool
}
