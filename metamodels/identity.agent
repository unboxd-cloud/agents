// identity.agent — the identity & security metamodel: principals, credentials,
// verified identities, sessions/tokens, and the roles/permissions that govern
// what they may do.
namespace unboxd.meta.identity

entity Principal {
    id: string required
    kind: string required
}

entity Credential {
    principal: Principal required
    kind: string required
    issuer: string
}

entity Identity {
    principal: Principal required
    spiffeId: string
    verified: bool
}

entity Session {
    principal: Principal required
    startedAt: datetime
    expiresAt: datetime
}

entity Token {
    session: Session required
    scope: string
}

entity Role {
    name: string required
    description: string
}

entity Permission {
    name: string required
    scope: string
}

entity Secret {
    name: string required
    ref: string
}

relation Authenticates Credential -> Principal {
    method: string
}

relation Holds Principal -> Role {
    grantedAt: datetime
}

relation Includes Role -> Permission {
    mandatory: bool
}
