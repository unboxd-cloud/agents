// identity.agent — the identity & security metamodel: principals (humans and
// service accounts), organizations and groups, credentials/keys/MFA, verified
// identities, sessions and tokens, and the roles/permissions/bindings and
// secrets that govern what a principal may do.
namespace unboxd.meta.identity

entity Principal {
    id: string required
    kind: string required
    displayName: string
    active: bool
}

entity Human extends Principal {
    email: string
    title: string
}

entity ServiceAccount extends Principal {
    owner: string
}

entity Organization {
    id: string required
    name: string required
}

entity Group {
    org: Organization required
    name: string required
}

entity Credential {
    principal: Principal required
    kind: string required
    issuer: string
    createdAt: datetime
    expiresAt: datetime
}

entity ApiKey {
    principal: Principal required
    prefix: string required
    lastUsedAt: datetime
}

entity MfaFactor {
    principal: Principal required
    kind: string required
    verified: bool
}

entity Identity {
    principal: Principal required
    spiffeId: string
    verified: bool
}

entity Session {
    principal: Principal required
    startedAt: datetime
    expiresAt: datetime
    ip: string
}

entity Token {
    session: Session required
    scope: string
    kind: string
}

entity Role {
    name: string required
    description: string
}

entity Permission {
    name: string required
    action: string required
    scope: string
}

entity RoleBinding {
    role: Role required
    principal: Principal required
    scope: string
}

entity Secret {
    name: string required
    ref: string
    rotationDays: int
}

relation HasGroup Organization -> Group {
    createdAt: datetime
}

relation MemberOf Principal -> Group {
    since: datetime
}

relation Authenticates Credential -> Principal {
    method: string
}

relation Protects MfaFactor -> Principal {
    primary: bool
}

relation Verifies Identity -> Principal {
    assurance: string
}

relation Binds RoleBinding -> Role {
    via: string
}

relation AppliesTo RoleBinding -> Principal {
    inherited: bool
}

relation Includes Role -> Permission {
    mandatory: bool
}

relation OwnsSecret Principal -> Secret {
    grantedAt: datetime
}

// Okta data-model alignment (conformance). Maps our identity types onto Okta
// resources; see https://developer.okta.com/docs/concepts/okta-data-model/.
vocabulary okta {
    term User means "an Okta user" maps to okta.User
    term Group means "an Okta group" maps to okta.Group
    term Application means "an Okta application" maps to okta.Application
    term AuthorizationServer means "an Okta authorization server" maps to okta.AuthorizationServer
    term Policy means "an Okta policy" maps to okta.Policy
    term Factor means "an Okta authenticator/factor" maps to okta.Factor
    term Device means "an Okta device" maps to okta.Device
    term Session means "an Okta session" maps to okta.Session
    term Journey means "an Okta identity journey/orchestration flow" maps to okta.Journey
    term Api means "the Okta APIs the platform adapts natively" maps to okta.Api
}

// User is a person principal with an Okta-style lifecycle status (staged,
// active, suspended, deactivated).
entity User extends Principal {
    login: string required
    email: string
    status: string
}

entity Application {
    name: string required
    signOnMode: string
}

entity AppAssignment {
    app: Application required
    principal: Principal required
    scope: string
}

entity AuthorizationServer {
    name: string required
    audience: string
}

entity Policy {
    name: string required
    type: string required
}

entity PolicyRule {
    policy: Policy required
    name: string required
    priority: int
}

entity Device {
    principal: Principal required
    platform: string
    managed: bool
}

relation Assigns Application -> AppAssignment {
    status: string
}

relation GovernsAccess Policy -> PolicyRule {
    priority: int
}

relation Enrolls Device -> Principal {
    at: datetime
}

// Okta-style identity journeys are composable orchestration flows of steps; the
// platform provides a native adapter to the Okta APIs (https://developer.okta.com/docs/api).
entity Journey {
    name: string required
    composable: bool
}

entity JourneyStep {
    journey: Journey required
    name: string required
    order: int
    kind: string
}

relation ComposesStep Journey -> JourneyStep {
    order: int
}
